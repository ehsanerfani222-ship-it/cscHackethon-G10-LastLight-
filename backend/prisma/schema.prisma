generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Crisis {
  id                 String    @id @default(uuid())
  type               String
  title              String
  location           String
  country            String
  lat                Float
  lng                Float
  severity           Float
  affectedPopulation Int
  description        String
  aiAnalysis         String
  safetyProtocols    String
  scientificData     String
  status             String    @default("active")
  dateLabel          String
  predictionScore    Float     @default(0)
  predictionNote     String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  posts              Post[]
  chatRooms          ChatRoom[]
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  avatar    String    @default("")
  bio       String    @default("")
  createdAt DateTime  @default(now())
  posts     Post[]
  comments  Comment[]
  reactions Reaction[]
  chatMessages ChatMessage[]
}

model Post {
  id        String     @id @default(uuid())
  content   String
  type      String     @default("discussion") // discussion | help_request | safety_tip | report
  author    User       @relation(fields: [authorId], references: [id])
  authorId  String
  crisis    Crisis?    @relation(fields: [crisisId], references: [id])
  crisisId  String?
  location  String     @default("")
  imageUrl  String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comments  Comment[]
  reactions Reaction[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reaction {
  id        String   @id @default(uuid())
  type      String   // like | heart | sos | strong
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
}

model ChatRoom {
  id          String        @id @default(uuid())
  name        String
  description String        @default("")
  crisis      Crisis?       @relation(fields: [crisisId], references: [id], onDelete: SetNull)
  crisisId    String?
  createdBy   String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Consultation {
  id                  String   @id @default(cuid())
  category            String
  symptom             String
  bodyArea            String
  severity            Int
  age                 Int
  additionalInfo      String?
  urgencyLevel        String
  urgencyColor        String
  headline            String
  immediateSteps      String
  doNotDo             String
  whenToCallEmergency String
  recoveryTips        String
  disclaimer          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
