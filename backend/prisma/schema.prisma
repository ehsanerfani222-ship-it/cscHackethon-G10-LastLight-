generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Crisis {
  id                 String   @id @default(uuid())
  type               String
  title              String
  location           String
  country            String
  lat                Float
  lng                Float
  severity           Float
  affectedPopulation Int
  description        String
  aiAnalysis         String
  safetyProtocols    String
  scientificData     String
  status             String   @default("active")
  dateLabel          String
  predictionScore    Float    @default(0)
  predictionNote     String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
