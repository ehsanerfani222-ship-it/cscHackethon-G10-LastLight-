generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Crisis {
  id                 String   @id @default(uuid())
  type               String
  title              String
  location           String
  country            String
  lat                Float
  lng                Float
  severity           Float
  affectedPopulation Int
  description        String
  aiAnalysis         String
  safetyProtocols    String   // JSON array stored as string
  scientificData     String   // JSON object stored as string
  status             String   @default("active")
  dateLabel          String   // YYYY-MM-DD for timeline queries
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Consultation {
  id         String   @id @default(cuid())
  category   String
  symptom    String
  bodyArea   String
  severity   Int
  age        Int
  result     Json
  createdAt  DateTime @default(now())
}